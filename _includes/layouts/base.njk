<!doctype html>
<html lang="{{ metadata.language }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
		<title>{{ title or metadata.title }}</title>
		<meta name="description" content="{{ description or metadata.description }}">
		<link rel="canonical" href="{{ page.url | htmlBaseUrl(metadata.url) }}">

		<meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)">
		<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-title" content="Robowen">

		<meta property="og:title" content="{{ title or metadata.title }}">
		<meta property="og:description" content="{{ description or metadata.description }}">
		<meta property="og:url" content="{{ page.url | htmlBaseUrl(metadata.url) }}">
		{% if ogImage %}<meta property="og:image" content="{{ ogImage | htmlBaseUrl(metadata.url) }}">{% endif %}
		<meta property="og:type" content="{{ ogType or 'website' }}">
		<meta property="og:site_name" content="{{ metadata.title }}">

		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:site" content="@robowen_io">
		<meta name="twitter:creator" content="@robowen_io">
		<meta name="twitter:title" content="{{ title or metadata.title }}">
		<meta name="twitter:description" content="{{ description or metadata.description }}">
		{% if ogImage %}<meta name="twitter:image" content="{{ ogImage | htmlBaseUrl(metadata.url) }}">{% endif %}

		{% if appleAppId and not isBeta %}
		<meta name="apple-itunes-app" content="app-id={{ appleAppId }}, app-argument={{ page.url | htmlBaseUrl(metadata.url) }}, affiliate-data=ct=site-banner-{{ page.fileSlug }}">
		{% endif %}

		<link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">
		<link rel="alternate" href="/feed/feed.json" type="application/json" title="{{ metadata.title }}">

		{%- css %}{% include "public/css/index.css" %}{% endcss %}

		<style>{% getBundle "css" %}</style>

		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Person",
					"@id": "{{ metadata.url }}#person",
					"name": {{ metadata.author.name | jsonEscape | safe }},
					"url": "{{ metadata.url }}",
					"jobTitle": "Independent iOS Developer",
					"knowsAbout": ["iOS development", "SwiftUI", "Astronomy", "Home automation", "Octopus Energy"],
					"sameAs": [
						"https://mastodon.social/@robowen",
						"https://bsky.app/profile/robowen.io",
						"https://github.com/robowen",
						"https://www.linkedin.com/in/robowen/"
					]
				},
				{
					"@type": "Organization",
					"@id": "{{ metadata.url }}#organization",
					"name": "Robowen",
					"url": "{{ metadata.url }}",
					"founder": { "@id": "{{ metadata.url }}#person" }
				}
			]
		}
		</script>

		<script
			src="https://cdn.telemetrydeck.com/websdk/telemetrydeck.min.js"
			data-app-id="881FDAD4-45B3-44AA-96A3-C3907003188A"
		></script>
	</head>
	<body{% if accent %} style="--accent: {{ accent }};"{% endif %}>
		<a href="#skip" class="visually-hidden">Skip to main content</a>

		<header class="site-header">
			<div class="site-header__inner">
				<a href="/" class="site-brand">
					<span class="site-brand__dot" aria-hidden="true"></span>
					{{ metadata.title }}
				</a>
				<nav class="site-nav" aria-label="Primary">
					<h2 class="visually-hidden">Top level navigation menu</h2>
					<ul>
					{%- for entry in collections.all | eleventyNavigation %}
						<li><a href="{{ entry.url }}"{% if entry.url == page.url %} aria-current="page"{% endif %}>{{ entry.title }}</a></li>
					{%- endfor %}
					</ul>
				</nav>
			</div>
		</header>

		<main id="skip" class="site-main">
			{{ content | safe }}
		</main>

		<footer class="site-footer">
			<div class="site-footer__inner">
				<p>© Robert Owen 2026</p>
				<div class="site-footer__links">
					<a href="mailto:hello@robowen.io">hello@robowen.io</a>
					<a href="/feed/feed.xml" aria-label="RSS feed">RSS</a>
					<a href="https://mastodon.social/@robowen" target="_blank" rel="noopener noreferrer" aria-label="Follow me on Mastodon">
						<img class="site-footer__icon" src="/img/mastodon.svg" alt="" width="20" height="20">
					</a>
				</div>
			</div>
		</footer>

		<!-- This page `{{ page.url | htmlBaseUrl }}` was built on {% currentBuildDate %} -->
	</body>
</html>
