<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": "{{ metadata.url }}"
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "{{ breadcrumbSection }}",
			"item": "{{ breadcrumbSectionUrl }}"
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": {{ title | jsonEscape | safe }},
			"item": "{{ page.url | htmlBaseUrl(metadata.url) }}"
		}
	]
}
</script>
